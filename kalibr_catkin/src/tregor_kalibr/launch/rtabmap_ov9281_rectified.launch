<?xml version="1.0"?>
<!--
  Камеры + мост ректификации + rtabmap (нужен apt: ros-noetic-rtabmap-ros).
  Если топики/remaps не совпадают с вашей версией пакета — см. rosnode info /rtabmap
  и подправьте remap или запускайте только stereo_rectify_bridge.launch + свой rtabmap.
-->
<launch>
  <arg name="rectify_yaml" default="$(find tregor_kalibr)/../../../kalibr_data/my_calib_75mm-orbslam3-rectify-input.yaml"/>
  <arg name="start_cameras" default="true"/>
  <arg name="rtabmapviz" default="true"/>
  <arg name="args" default="--delete_db_on_start" doc="Аргументы CLI rtabmap, например -d"/>

  <include file="$(find tregor_kalibr)/launch/stereo_rectify_bridge.launch">
    <arg name="rectify_yaml" value="$(arg rectify_yaml)"/>
    <arg name="start_cameras" value="$(arg start_cameras)"/>
  </include>

  <node pkg="rtabmap_ros" type="rtabmap" name="rtabmap" output="screen" args="$(arg args)">
    <param name="frame_id" type="string" value="tregor_stereo_left_optical"/>
    <param name="map_frame_id" type="string" value="map"/>
    <param name="odom_frame_id" type="string" value="odom"/>
    <param name="subscribe_stereo" type="bool" value="true"/>
    <param name="approx_sync" type="bool" value="true"/>
    <param name="publish_tf" type="bool" value="true"/>
    <remap from="left/image_rect" to="/stereo/left/image_rect"/>
    <remap from="right/image_rect" to="/stereo/right/image_rect"/>
    <remap from="left/camera_info" to="/stereo/left/camera_info"/>
    <remap from="right/camera_info" to="/stereo/right/camera_info"/>
  </node>

  <node if="$(arg rtabmapviz)" pkg="rtabmap_ros" type="rtabmapviz" name="rtabmapviz" output="screen">
    <remap from="left/image_rect" to="/stereo/left/image_rect"/>
    <remap from="right/image_rect" to="/stereo/right/image_rect"/>
    <remap from="left/camera_info" to="/stereo/left/camera_info"/>
    <remap from="right/camera_info" to="/stereo/right/camera_info"/>
  </node>
</launch>
